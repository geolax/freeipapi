{
    "name": "geolax/freeipapi",
    "description": "FreeIPAPI driver addon for geolax/geolocate",
    "keywords": [
        "laravel",
        "geolocate",
        "freeipapi",
        "freeipapi.com",
        "geolocation",
        "addon"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Bishwajit Adhikary",
            "email": "bishwajitcadhikary@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "geolax/geolocate": "^1.0",
        "illuminate/http": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Geolax\\FreeIpApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Geolax\\FreeIpApi\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Geolax\\FreeIpApi\\FreeIpApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
